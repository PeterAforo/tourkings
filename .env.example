DATABASE_URL="postgresql://user:password@localhost:5432/tourkings?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Flutterwave v4 (OAuth — Dashboard → Developer / API: Client ID & Client Secret)
# https://developer.flutterwave.com/v4.0/docs/environments
FLUTTERWAVE_CLIENT_ID=""
FLUTTERWAVE_CLIENT_SECRET=""
# "true" = developersandbox-api; "false" = live (f4bexperience). If unset: sandbox except when NODE_ENV=production.
FLUTTERWAVE_USE_SANDBOX="true"
# Ghana mobile money network for orchestrator direct-charges (e.g. MTN, VOD)
FLUTTERWAVE_MOMO_NETWORK="MTN"

# v4 webhooks: use the secret from Dashboard → Webhooks; verify flutterwave-signature (HMAC-SHA256, base64)
FLUTTERWAVE_WEBHOOK_SECRET=""
# Optional: legacy v3 webhook header verif-hash exact match
# FLUTTERWAVE_WEBHOOK_HASH=""

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
CONTACT_EMAIL="info@tourkings.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
